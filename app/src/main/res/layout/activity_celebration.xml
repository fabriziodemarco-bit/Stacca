<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout della CelebrationActivity.
    Usa un FrameLayout per sovrapporre gli emoji "pioggia" (posizionati con margin)
    al contenuto principale centrato.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- ======================================================
         EMOJI PIOGGIA — 6 TextView animate via TranslationY.
         Partono da sopra lo schermo (translationY = -300dp
         impostato via codice) e cadono verso il basso.
         Posizionate a X diverse tramite layout_marginStart.
    ======================================================= -->
    <TextView
        android:id="@+id/rainEmoji1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎉"
        android:textSize="40sp"
        android:layout_marginStart="20dp"
        android:translationY="-300dp" />

    <TextView
        android:id="@+id/rainEmoji2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⭐"
        android:textSize="32sp"
        android:layout_marginStart="80dp"
        android:translationY="-300dp" />

    <TextView
        android:id="@+id/rainEmoji3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌟"
        android:textSize="36sp"
        android:layout_marginStart="150dp"
        android:translationY="-300dp" />

    <TextView
        android:id="@+id/rainEmoji4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎊"
        android:textSize="38sp"
        android:layout_marginStart="230dp"
        android:translationY="-300dp" />

    <TextView
        android:id="@+id/rainEmoji5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨"
        android:textSize="30sp"
        android:layout_marginStart="310dp"
        android:translationY="-300dp" />

    <TextView
        android:id="@+id/rainEmoji6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎉"
        android:textSize="34sp"
        android:layout_marginStart="60dp"
        android:translationY="-300dp" />

    <!-- ======================================================
         CONTENUTO PRINCIPALE — centrato verticalmente
    ======================================================= -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <!-- Spacer top -->
            <View
                android:layout_width="0dp"
                android:layout_height="40dp" />

            <!-- Emoji principale animata -->
            <TextView
                android:id="@+id/tvCelebEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉"
                android:textSize="96sp"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <!-- Titolo "SEI LIBERO!" -->
            <TextView
                android:id="@+id/tvCelebTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/celebration_title"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/tertiary"
                android:gravity="center"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:layout_marginBottom="32dp" />

            <!-- Card STREAK -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/background_card_elevated"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                app:strokeColor="@color/tertiary"
                app:strokeWidth="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/celebration_streak_label"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:textAllCaps="true"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="4dp" />

                    <!-- Numero di streak grande -->
                    <TextView
                        android:id="@+id/tvCelebStreakCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textSize="72sp"
                        android:textStyle="bold"
                        android:textColor="@color/tertiary"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center" />

                    <!-- Sottotitolo "giorni" -->
                    <TextView
                        android:id="@+id/tvCelebStreakDays"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="giorni"
                        android:textSize="18sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Badge NUOVO RECORD (visibilità GONE di default, mostrato dal codice) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNewRecord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="@color/premium_gold"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/celebration_new_record"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/background_dark"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:gravity="center" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Messaggio ironico random -->
            <TextView
                android:id="@+id/tvCelebMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:fontStyle="italic"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="40dp" />

            <!-- Bottone "Vado a vivere" -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCelebClose"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/celebration_btn_close"
                android:textSize="18sp"
                android:textStyle="bold"
                style="@style/Widget.Stacca.Button.Primary"
                android:backgroundTint="@color/tertiary"
                app:cornerRadius="16dp" />

            <!-- Spacer bottom -->
            <View
                android:layout_width="0dp"
                android:layout_height="40dp" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
