<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Plurale per il banner del trial in MainActivity.
        Gestisce correttamente "1 giorno" vs "X giorni".
        %d = numero di giorni rimasti.
    -->
    <plurals name="trial_days_left_banner">
        <item quantity="one">⏳ Ti resta 1 giorno di prova gratuita</item>
        <item quantity="other">⏳ Ti restano %d giorni di prova gratuita</item>
    </plurals>

    <!--
        Plurale per i giorni di streak in CelebrationActivity.
        %d = numero di giorni di streak.
    -->
    <plurals name="streak_days">
        <item quantity="one">1 giorno</item>
        <item quantity="other">%d giorni</item>
    </plurals>
</resources>
